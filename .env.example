POSTGRES_PASSWORD="replace-with-a-strong-postgres-password"
DATABASE_URL="postgresql://guanyu:replace-with-a-strong-postgres-password@localhost:5432/guanyu?schema=public&connection_limit=10&pool_timeout=20"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
APP_ENCRYPTION_KEY="replace-with-a-long-random-secret-for-db-secrets"
NEXTAUTH_URL="http://localhost:3000"
# 局域网手机测试时改成 Mac 的局域网地址，例如:
# NEXTAUTH_URL="http://YOUR_LAN_IP:3000"
# NEXT_ALLOWED_DEV_ORIGINS="YOUR_LAN_IP"
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL_DEFAULT="gpt-4o"
# 超级管理员白名单，逗号分隔；也可直接在数据库把 User.role 设为 super_admin。
SUPER_ADMIN_EMAILS=""
SUPER_ADMIN_IDS=""
# Tavily 默认按账号在“账号管理”中加密保存；此处仅作为部署说明预留。
TAVILY_API_KEY=""
# Serper.dev 默认按账号或管理员设置加密保存；此处仅作为部署说明预留。
SERPER_API_KEY=""
# 阿里云 DirectMail 邮件验证码配置。
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_DM_ACCOUNT_NAME=""
ALIYUN_DM_FROM_ALIAS="观隅"
ALIYUN_DM_REGION="cn-hangzhou"
# SMTP 邮件验证码配置；配置后优先于 DirectMail AccessKey。
SMTP_HOST="smtpdm.aliyun.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_FROM_NAME="观隅"
