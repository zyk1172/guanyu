# QNAP / Container Station example.
# PostgreSQL data is persisted by docker-compose.qnap.yml at:
# /share/SSD/container/guanyu/postgres
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
DATABASE_URL=postgresql://guanyu:replace-with-a-strong-postgres-password@127.0.0.1:55432/guanyu?schema=public&connection_limit=10&pool_timeout=20
NODE_IMAGE=node:22-alpine
POSTGRES_IMAGE=postgres:18.2
NEXTAUTH_SECRET=replace-with-a-long-random-secret
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret-for-db-secrets
NEXTAUTH_URL=http://YOUR_NAS_IP:5000
OPENAI_API_KEY=
OPENAI_BASE_URL=http://127.0.0.1:3000/v1
OPENAI_MODEL_DEFAULT=gemini-3.1-pro-preview
SUPER_ADMIN_EMAILS=
SUPER_ADMIN_IDS=
# Tavily 默认按账号在“账号管理”中加密保存；此处仅作为部署说明预留。
TAVILY_API_KEY=
# Serper.dev 默认按账号或管理员设置加密保存；此处仅作为部署说明预留。
SERPER_API_KEY=
# 阿里云 DirectMail 邮件验证码配置。
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_DM_ACCOUNT_NAME=
ALIYUN_DM_FROM_ALIAS=观隅
ALIYUN_DM_REGION=cn-hangzhou
# SMTP 邮件验证码配置；配置后优先于 DirectMail AccessKey。
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=观隅
NODE_ENV=production
TZ=Asia/Shanghai
